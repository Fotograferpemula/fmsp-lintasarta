generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────
// 1. MODEL UTAMA PHASE 1 (OPERASIONAL - SESUAI BRD)
// ────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         String   @default("user") // superadmin | manager_fms | admin_pusat | admin_regional | admin_lokasi | user
  passwordHash String
  isActive     Boolean  @default(true)
  mustChangePassword Boolean @default(false) // Force password change on first login
  department   String?  // e.g. FM, IT, HR
  phone        String?
  region       String?  // Region/lokasi untuk filter data (admin_regional, admin_lokasi)
  // Account lockout (brute force protection)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastFailedLogin     DateTime?
  // Password reset (admin-approval flow)
  resetToken          String?   @unique
  resetTokenExpiry    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  passwordResetRequests PasswordResetRequest[]
  pushSubscriptions     PushSubscription[]

  @@map("users")
}

// Admin-approval password reset request
model PasswordResetRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String   @default("pending") // pending | approved | rejected
  requestedAt DateTime @default(now())
  reviewedBy  String?  // Admin email who approved/rejected
  reviewedAt  DateTime?
  reason      String?  // Optional reason from user
  token       String?  @unique // Generated after approval, used to reset
  tokenExpiry DateTime?

  @@index([userId])
  @@index([status])
  @@map("password_reset_requests")
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String   // Public key for encryption
  auth       String   // Auth secret
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

model Asset {
  id                    String              @id @default(cuid())
  name                  String
  type                  String              // land | office | facility | vehicle
  location              String
  specs                 Json                // Spesifikasi teknis dinamis
  status                String              @default("good") // good | warning | broken
  bookValue             Float
  // Lifecycle fields (merged from AssetLifecycleRecord)
  purchaseDate          DateTime?           // Tanggal pembelian
  purchaseCost          Float?              // Harga beli awal
  expectedLifeYrs       Int?                // Estimasi umur pakai (tahun)
  lifecycleStatus       String              @default("operational") // operational | depreciated | retired
  photos                String[]            @default([]) // URLs of asset photos
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?           // Soft delete
  transfers             AssetTransfer[]
  legalDocuments        LegalDocument[]
  maintenanceSchedules  MaintenanceSchedule[]
  workOrders            WorkOrder[]

  @@index([type])
  @@index([status])
  @@index([location])
  @@map("assets")
}

model AssetTransfer {
  id            String   @id @default(cuid())
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fromLocation  String
  toLocation    String
  transferredBy String
  transferredAt DateTime @default(now())
  notes         String?

  @@index([assetId])
  @@map("asset_transfers")
}

model LegalDocument {
  id               String   @id @default(cuid())
  assetId          String
  asset            Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  title            String
  documentType     String   // pbg_imb | slf | certificate | insurance | tax_building | tax_vehicle | fire_protection | elevator_sio | drainage
  documentUrl      String
  issueDate        DateTime
  expiryDate       DateTime
  complianceStatus String   @default("valid") // valid | warning | expired
  // PUPR fields (merged from PuprDocument)
  regNumber        String?  @unique  // Nomor registrasi dokumen PUPR
  issuingAuthority String?            // "Kemen PUPR", "Pemkot", "Dinas Damkar"
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([expiryDate])
  @@index([complianceStatus])
  @@index([assetId])
  @@map("legal_documents")
}

model Notification {
  id             String    @id @default(cuid())
  recipientEmail String
  type           String    @default("email") // email | dashboard
  title          String
  message        String    @db.Text
  status         String    @default("pending") // pending | sent | failed
  scheduledAt    DateTime
  sentAt         DateTime?
  readAt         DateTime? // Kapan notifikasi dibaca oleh penerima

  @@index([status])
  @@index([scheduledAt])
  @@map("notifications")
}

// ────────────────────────────────────────────────────────
// 2. MODEL PHASE 2B: PREVENTIVE MAINTENANCE & VENDOR
// ────────────────────────────────────────────────────────

model MaintenanceSchedule {
  id           String   @id @default(cuid())
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  title        String   // "Overhaul AC Presisi", "Kalibrasi UPS"
  intervalDays Int      // Interval siklus (misal: 90 hari)
  lastPerformed DateTime
  nextDue      DateTime
  assignedTo   String?  // NIP teknisi
  status       String   @default("scheduled") // scheduled | overdue | completed
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([nextDue])
  @@index([status])
  @@map("maintenance_schedules")
}

model VendorContract {
  id            String   @id @default(cuid())
  vendorName    String
  contractTitle String   // "Kontrak Perawatan Genset", "Sewa Gedung Lantai 3"
  contractType  String   // maintenance | lease | insurance | service
  startDate     DateTime
  endDate       DateTime
  value         Float    // Nilai kontrak (Rp)
  pic           String   // Person in charge email
  status        String   @default("active") // active | expiring | expired | terminated
  documentUrl   String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime? // Soft delete

  @@index([endDate])
  @@index([status])
  @@map("vendor_contracts")
}

// ────────────────────────────────────────────────────────
// 3. MODEL UNTUK 8 MODUL MANAGEMENT (DATABASE CRUD)
// ────────────────────────────────────────────────────────

// A. HRD (includes Security Guard — merged)
model Employee {
  id           String    @id @default(cuid())
  nip          String    @unique
  name         String
  role         String    // teknisi_mep | operator_bas | cleaning | security | admin | management
  department   String    // Engineering | Housekeeping | Security | Admin | Management
  phone        String
  email        String
  joinDate     DateTime
  contractType String    // permanent | pkwt | outsource
  status       String    @default("active") // active | on_leave | inactive
  baseSalary   Float
  skills       String[]
  // Security-specific fields (merged from SecurityGuard)
  gadaLevel    String?   // Khusus security: pratama | madya | utama
  ktaNumber    String?   // Nomor KTA Satpam
  ktaExpiry    DateTime? // Masa berlaku KTA
  createdAt    DateTime  @default(now())
  deletedAt    DateTime? // Soft delete

  @@index([role])
  @@index([department])
  @@map("employees")
}

// C. Inventory
model InventoryItem {
  id            String   @id @default(cuid())
  sku           String   @unique
  name          String
  category      String   // spare_part | electrical | plumbing | safety_ppe | chemical | consumable
  qty           Int
  minQty        Int
  maxQty        Int
  unit          String   // pcs | box | kg | liter | roll
  location      String   // Warehouse A, B, etc.
  unitPrice     Float
  lastRestocked DateTime @default(now())
  updatedAt     DateTime @updatedAt @default(now())

  @@map("inventory_items")
}

// D. SMK3 Safety
model Smk3Item {
  id          String   @id @default(cuid())
  item        String   // APAR | Electrical Control | Scaffold | Structural Pillar
  location    String
  lastChecked DateTime
  status      String   @default("ok") // ok | warning | danger
  checkedBy   String
  updatedAt   DateTime @updatedAt @default(now())

  @@map("smk3_items")
}

// E. Accounting (with RAB relation)
model AccountingTransaction {
  id          String     @id @default(cuid())
  date        DateTime
  description String
  type        String     // income | expense
  amount      Float
  category    String     // operasional | maintenance | utility | salary | lease
  rabBudgetId String?    // Link ke anggaran RAB
  rabBudget   RabBudget? @relation(fields: [rabBudgetId], references: [id])
  updatedAt   DateTime   @updatedAt @default(now())

  @@index([category])
  @@index([date])
  @@index([rabBudgetId])
  @@map("accounting_transactions")
}

// F. RAB / Anggaran
model RabBudget {
  id              String                 @id @default(cuid())
  year            Int
  department      String                 // Engineering | Housekeeping | Security | Admin | IT
  category        String                 // Operasional | Capex | Opex
  allocatedAmount Float
  spentAmount     Float
  transactions    AccountingTransaction[]
  updatedAt       DateTime               @updatedAt @default(now())

  @@map("rab_budgets")
}

// ────────────────────────────────────────────────────────
// 4. MODEL PHASE 2D: WORK ORDER / TIKET KERJA (v2)
// ────────────────────────────────────────────────────────

model WorkOrder {
  id             String    @id @default(cuid())
  ticketNumber   String    @unique // WO-2026-0001
  title          String
  description    String    @db.Text
  priority       String    // critical | high | medium | low
  category       String    // Dinamis dari MasterData wo_category
  assetId        String?
  asset          Asset?    @relation(fields: [assetId], references: [id])
  assignedTo     String?   // Employee NIP
  reportedBy     String    // User email
  // Status: draft | pending_approval | approved_l1 | pending_l2 |
  //         assigned | in_progress | on_hold | resolved | verified |
  //         reopened | rejected | closed
  status         String    @default("draft")
  slaDeadline    DateTime?
  resolvedAt     DateTime?

  // ── 2-Tier Approval ──
  approvalLevel  Int       @default(0) // 0=belum, 1=L1 done, 2=L2 done
  approvedL1By   String?   // Email admin lokasi/regional
  approvedL1At   DateTime?
  approvedL2By   String?   // Email manager/admin pusat
  approvedL2At   DateTime?
  rejectedBy     String?
  rejectedAt     DateTime?
  rejectedReason String?   @db.Text

  // ── Verification (resolved → verified → closed) ──
  verifiedBy     String?   // Pelapor atau Admin
  verifiedAt     DateTime?

  // ── Cost Tracking ──
  estimatedCost  Float?    // Estimasi biaya sebelum approval
  actualCost     Float?    // Biaya aktual setelah selesai

  // ── Escalation ──
  escalationLevel Int      @default(0) // 0=normal, 1=escalated, 2=critical
  escalatedAt     DateTime?

  // ── Follow-up / Parent-Child ──
  parentWoId     String?
  parentWo       WorkOrder?  @relation("WoFollowUp", fields: [parentWoId], references: [id])
  childWos       WorkOrder[] @relation("WoFollowUp")

  photos         String[]  @default([]) // URLs of uploaded photos
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime? // Soft delete
  statusLogs     WorkOrderStatusLog[]

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([assignedTo])
  @@index([approvalLevel])
  @@index([assetId])
  @@index([parentWoId])
  @@map("work_orders")
}

model WorkOrderStatusLog {
  id          String    @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  fromStatus  String    // Status sebelumnya
  toStatus    String    // Status baru
  changedBy   String    // Email user yang mengubah
  reason      String?   // Alasan (khusus reject/close/on_hold)
  createdAt   DateTime  @default(now())

  @@index([workOrderId])
  @@map("work_order_status_logs")
}

// ── WO Approval Configuration per Category ──
model WoApprovalConfig {
  id              String   @id @default(cuid())
  category        String   @unique // Matches MasterData wo_category code
  requireL1       Boolean  @default(true)
  l1Roles         String[] @default(["admin_lokasi", "admin_regional"])
  requireL2       Boolean  @default(false)
  l2Roles         String[] @default(["manager_fms", "admin_pusat"])
  l2Priorities    String[] @default(["critical", "high"]) // Kapan L2 wajib
  autoApproveBelow Float?  // Auto-approve jika estimatedCost di bawah nilai ini
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("wo_approval_configs")
}

// ── WO SLA Configuration per Category × Region × Priority ──
model WoSlaConfig {
  id              String   @id @default(cuid())
  category        String   // wo_category code (or "*" for default)
  region          String   // region code (or "*" for default)
  priority        String   // critical | high | medium | low
  responseMinutes Int      // Target response time in minutes
  resolveMinutes  Int      // Target resolution time in minutes
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([category, region, priority])
  @@map("wo_sla_configs")
}

// ────────────────────────────────────────────────────────
// 5. MODEL MASA DEPAN (VISI IOT / DCIM / ALARM)
// ────────────────────────────────────────────────────────

model HardwareDevice {
  id            String   @id @default(cuid())
  name          String
  protocol      String   // bacnet | modbus-tcp | mqtt | rest
  ipAddress     String?
  port          Int      @default(502)
  enabled       Boolean  @default(true)
  status        String   @default("disconnected") // connected | disconnected | error
  lastSeen      DateTime?
  config        Json     @default("{}")
  subsystem     String   // hvac | energy | fire | water
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("hardware_devices")
}

model DeviceState {
  id        String   @id @default(cuid())
  moduleId  String   // hvac | energy | elevator | ups | chiller
  data      Json
  updatedAt DateTime @updatedAt

  @@map("device_states")
}

model TimeSeries {
  id        BigInt   @id @default(autoincrement())
  timestamp DateTime
  deviceId  String
  metric    String   // temperature | humidity | power_kw | pue
  value     Float
  unit      String

  @@index([deviceId, metric, timestamp])
  @@map("time_series")
}

model Alert {
  id             String    @id @default(cuid())
  severity       String    // critical | major | minor
  subsystem      String
  message        String
  equipment      String
  status         String    @default("active") // active | acknowledged | resolved
  acknowledgedBy String?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@map("alerts")
}

model AuditLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  user      String
  action    String
  resource  String
  details   String   @default("")
  ip        String   @default("127.0.0.1")

  @@index([user])
  @@index([action])
  @@index([timestamp])
  @@map("audit_logs")
}

// ────────────────────────────────────────────────────────
// MASTER DATA — Kelola jenis fasilitas, tipe aset, lokasi, dll
// ────────────────────────────────────────────────────────
model MasterData {
  id          String   @id @default(cuid())
  category    String   // e.g. "asset_type", "facility_type", "location", "document_type", "asset_status", "department"
  code        String   // e.g. "facility", "vehicle", "land", "office"
  label       String   // e.g. "Fasilitas Kantor", "Kendaraan", "Tanah", "Gedung Kantor"
  description String   @default("")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, code])
  @@index([category])
  @@map("master_data")
}

// ────────────────────────────────────────────────────────
// APP SETTINGS — Konfigurasi Sistem (menggantikan hardcoded)
// ────────────────────────────────────────────────────────

model AppSetting {
  key         String   @id
  value       String
  label       String   // Label untuk tampilan UI
  group       String   // smtp | notification | company | system
  inputType   String   @default("text") // text | number | password | email
  updatedAt   DateTime @updatedAt

  @@index([group])
  @@map("app_settings")
}
