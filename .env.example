# ════════════════════════════════════════════════════════
# FMSP Lintasarta — Environment Variables
# SECURITY: Copy this file to .env and CHANGE ALL secrets!
# DO NOT use default values in production.
# ════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
# ⚠️ CHANGE the password to a strong random string in production!
DATABASE_URL="postgresql://fmsp_user:CHANGE_THIS_STRONG_PASSWORD@localhost:5432/fmsp_db?schema=public&connection_limit=15&pool_timeout=10"
POSTGRES_USER=fmsp_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=fmsp_db

# ── Auth ──────────────────────────────────────────────
# ⚠️ CRITICAL: JWT_SECRET MUST be changed. App will NOT start without it.
# Generate: openssl rand -hex 64
JWT_SECRET="GENERATE_WITH_openssl_rand_hex_64"

# ── Google OAuth SSO ──────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI to: https://your-domain.com
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# ── App ───────────────────────────────────────────────
PORT=4101
NODE_ENV=development
NEXT_PUBLIC_APP_BASE_URL=http://localhost:4101

# ── Email (SMTP) ──────────────────────────────────────
# Gunakan SMTP Outlook, Gmail, atau Resend.com
# Jika kosong, mode mock via Ethereal (lihat log untuk preview URL)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@lintasarta.co.id
SMTP_PASSWORD=your_smtp_password

# ── Cron Security ─────────────────────────────────────
# Secret untuk proteksi endpoint /api/cron/*
# ⚠️ Generate: openssl rand -hex 32
CRON_SECRET="GENERATE_WITH_openssl_rand_hex_32"

# ── Web Push (VAPID) ─────────────────────────────────
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_CONTACT="mailto:admin@lintasarta.co.id"

# ── Local AI (Ollama) ─────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5
